# Required in production (defaults above work for bootstrapping; set real values in Railway)
JWT_SECRET=your-256-bit-or-longer-secret-here
GOOGLE_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com,your-android-client-id.apps.googleusercontent.com
GUARDIAN_API_KEY=your-guardian-api-key

# MySQL — add a MySQL service on Railway and link it to this backend.
# Railway injects MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE, and MYSQL_URL automatically.

# Optional
JWT_EXPIRATION_MS=86400000
SPRING_PROFILES_ACTIVE=prod
